# =============================================================================
# Variables d'environnement — copie ce fichier en ".env" et remplis les valeurs.
# NE JAMAIS committer le fichier .env (il contient des secrets).
# =============================================================================

# Connexion à la base de données MongoDB (MongoDB Atlas, gratuit).
# Exemple : mongodb+srv://utilisateur:motdepasse@cluster0.xxxxx.mongodb.net/padel-house
DATABASE_URI=

# Clé secrète Payload : une longue chaîne aléatoire.
# Génère-la avec :  openssl rand -base64 32
PAYLOAD_SECRET=

# Stockage des images uploadées (Vercel Blob).
# Laisse vide en local (les images iront dans le dossier /media).
# En production, Vercel le remplit automatiquement quand tu crées un Blob Store.
BLOB_READ_WRITE_TOKEN=
